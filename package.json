{
  "name": "ai-hub",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite",
    "dev:server": "cd server && node --watch index.js",
    "build": "vite build",
    "preview": "vite preview",
    "install:server": "cd server && npm install",
    "postinstall": "npm run install:server",
    "deploy:vercel": "npx vercel --prod",
    "deploy:netlify": "npx netlify deploy --prod --dir=dist",
    "deploy:pages": "npx wrangler pages deploy dist --project-name=ai-hub"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.5.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.1.2",
    "vite": "^6.3.1"
  }
}
